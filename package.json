{
  "name": "@maurogoncalo/clickclick",
  "version": "0.1.3",
  "description": "Generate social images by screenshotting HTML with Playwright.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "social-image",
    "open-graph",
    "playwright",
    "screenshot",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mintyPT/clickclick.git"
  },
  "bugs": {
    "url": "https://github.com/mintyPT/clickclick/issues"
  },
  "homepage": "https://github.com/mintyPT/clickclick#readme",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "clickclick": "dist/cli/index.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "dev": "tsx src/cli/index.ts",
    "examples:contact-sheet": "node scripts/create-example-contact-sheet.mjs",
    "examples:readme": "node scripts/generate-example-readme.mjs",
    "examples:render": "node scripts/render-example-set.mjs",
    "examples:scaffold": "node scripts/scaffold-example-set.mjs",
    "test": "vitest run",
    "pack:dry": "npm run build && npm pack --dry-run --cache .npm-cache",
    "pack:verify": "npm run build && mkdir -p .tmp && npm pack --dry-run --json --cache .npm-cache > .tmp/npm-pack.json && node scripts/verify-package.mjs .tmp/npm-pack.json",
    "release:check": "npm run check && npm test && npm run pack:verify"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "playwright": "^1.45.3",
    "pngjs": "^7.0.0",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/pngjs": "^6.0.5",
    "execa": "^9.3.0",
    "tsup": "^8.1.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.4"
  }
}
