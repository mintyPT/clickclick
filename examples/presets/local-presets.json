{
  "presets": [
    {
      "name": "campaign-card",
      "description": "Local campaign card backed by a schema and template layers.",
      "html": "<main><p data-layer=\"label\">Campaign</p><h1 data-layer=\"title\">Launch faster with local presets</h1><p data-layer=\"subtitle\">Teams can reuse project-specific layouts without editing ClickClick source.</p></main>",
      "css": "html,body,main{margin:0;width:100%;height:100%;box-sizing:border-box}main{display:grid;align-content:center;gap:18px;padding:56px;background:#f8fafc;color:#111827;font-family:Inter,Arial,sans-serif}p{margin:0}.label{font-size:18px}h1{margin:0;max-width:780px;font-size:56px;line-height:1.02}.subtitle{max-width:620px;font-size:25px;line-height:1.32;color:#475569}[data-layer=label]{width:max-content;border:2px solid #22c55e;border-radius:999px;padding:8px 14px;color:#166534;font-weight:700;text-transform:uppercase;letter-spacing:0}",
      "viewport": { "width": 1200, "height": 630 },
      "options": [
        {
          "name": "title",
          "description": "Title text",
          "type": "string",
          "required": true,
          "layer": "title"
        },
        {
          "name": "subtitle",
          "description": "Subtitle text",
          "type": "string",
          "default": "Teams can reuse project-specific layouts without editing ClickClick source.",
          "layer": "subtitle"
        },
        {
          "name": "label",
          "description": "Label text",
          "type": "string",
          "default": "Campaign",
          "layer": "label"
        }
      ]
    }
  ]
}
